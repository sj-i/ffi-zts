{
    "name": "sj-i/ffi-zts",
    "description": "Embed a ZTS PHP interpreter inside an NTS PHP process via FFI and run ZTS-only extensions (e.g. pecl/parallel) from a plain NTS CLI.",
    "type": "library",
    "license": "MIT",
    "keywords": ["ffi", "zts", "parallel", "embed", "threads"],
    "authors": [
        {"name": "sj-i"}
    ],
    "require": {
        "php": ">=8.4,<8.5",
        "ext-ffi": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SjI\\FfiZts\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SjI\\FfiZts\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/ffi-zts"
    ],
    "scripts": {
        "post-install-cmd": "SjI\\FfiZts\\Installer::fetchBinaries",
        "post-update-cmd":  "SjI\\FfiZts\\Installer::fetchBinaries"
    },
    "extra": {
        "ffi-zts": {
            "php-abi": "8.4",
            "release-asset-format": "libphp-{phpabi}-{arch}-{libc}.tar.gz"
        }
    },
    "config": {
        "sort-packages": true
    }
}
